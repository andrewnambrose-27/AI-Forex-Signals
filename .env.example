# App
ENVIRONMENT=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Accepts one URL, comma-separated URLs, or a JSON list.
CORS_ORIGINS=http://localhost:3000

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/forex_signals
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=forex_signals

# External providers
MARKET_DATA_API_KEY=
NEWS_API_KEY=

# IG Markets
# Use DEMO unless you have explicitly decided to connect a live read-only account.
IG_ENVIRONMENT=DEMO
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_ID=
ECONOMIC_CALENDAR_PROVIDER=fmp
FMP_API_KEY=
NEWS_SYNC_INTERVAL_MINUTES=15
NEWS_BLOCK_BEFORE_HIGH_MINUTES=60
NEWS_BLOCK_AFTER_HIGH_MINUTES=30
NEWS_BLOCK_BEFORE_MEDIUM_MINUTES=20
NEWS_BLOCK_AFTER_MEDIUM_MINUTES=10
